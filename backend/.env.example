# ─── Secrets & Configuration ─────────────────────────────────────────────────

# LLM provider identifier — e.g. "gemini", "openai", "anthropic"
LLM_PROVIDER=

# API key for the selected LLM provider
LLM_API_KEY=

# Provider-specific model string — e.g. "gemini/gemini-1.5-pro", "gpt-4o", "claude-3-5-sonnet-20241022"
LLM_MODEL=

# VirusTotal Public API v3 key (free tier)
VIRUSTOTAL_API_KEY=

# Supabase project URL — e.g. https://xyzabcdefg.supabase.co
SUPABASE_URL=

# Supabase service role key — SERVER-SIDE ONLY; never expose to the frontend
SUPABASE_SERVICE_KEY=

# Supabase anon key — read-only frontend access (if used); restricted by RLS
SUPABASE_ANON_KEY=

# Deployed frontend URL for CORS lock-down — e.g. https://phishshield.vercel.app
ALLOWED_ORIGIN=

# Per-IP rate limit for analysis endpoints (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# TTL for cached VirusTotal results (hours)
CACHE_TTL_HOURS=24
