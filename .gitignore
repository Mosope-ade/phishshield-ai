# ──────────────────────────────────────────────────────────────────────────────
# PhishShield AI — Consolidated Gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ─── Secrets & Environment Variables ──────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
*.env.*
backend/.env
frontend/.env

# ─── Python Virtual Environments & Packages ───────────────────────────────────
.venv/
# ─── Python Caches & Compiled Files ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.mypy_cache/
.dmypy.json
.pyre/
.ruff_cache/

# ─── Node & Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
.vite/
frontend/.vite/
*.tsbuildinfo

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.hypothesis/
coverage.xml
.nyc_output/

# ─── Logs & Cache ─────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── IDEs, Text Editors, & OS Files ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# ─── Runtime / Temporary Directories ──────────────────────────────────────────
/tmp/
uploads/
PLAN.md
UI.md
SECURITY.md
